# HUBSPOT_AUTH_URL=https://app.hubspot.com/oauth/authorize
# HUBSPOT_TOKEN_URL=https://api.hubapi.com/oauth/v1/token
# HUBSPOT_MCP_URL=https://mcp.hubspot.com
